# MongoDB Atlas - Remplacez par votre connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/medifollow?retryWrites=true&w=majority

# JWT - Changez en production
JWT_SECRET=medifollow-secret-key-change-in-production

# MFA - Email de confirmation
FRONTEND_URL=http://localhost:5174
# Serveur SMTP (ex: smtp.gmail.com pour Gmail - pas l'adresse email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=mot-de-passe-application
SMTP_FROM=MediFollow <noreply@medifollow.com>
