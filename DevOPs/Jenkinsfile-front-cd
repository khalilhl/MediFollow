pipeline {
    agent any
    environment {
        K8S_NAMESPACE = 'medifollow-staging'
    }
    
    stages {
        stage('Checkout Repository') {
            steps {
                checkout scm
            }
        }
        stage('Build Docker Image (Nginx)') {
            steps {
                dir('Front_End/CODE-REACT') {
                    echo "Building Frontend Docker Image..."
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                        sh 'docker build --network=host -t "$DOCKER_USER/medifollow-front:latest" .'
                    }
                }
            }
        }
        stage('Push to DockerHub') {
            steps {
                echo "Logging into DockerHub (bypassing 2FA via Token) and pushing image..."
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                    sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                    sh 'docker push "$DOCKER_USER/medifollow-front:latest"'
                }
            }
        }
        stage('Deploy to Vercel') {
            steps {
                echo "Triggering Vercel Cloud Automation..."
                // Force lowercase name override to bypass Vercel API crash
                sh 'echo \'{"name": "medifollow-frontend"}\' > vercel.json'
                withCredentials([string(credentialsId: 'VERCEL_TOKEN', variable: 'VERCEL_TOKEN')]) {
                    sh 'npx vercel --prod --yes --token $VERCEL_TOKEN'
                }
            }
        }
        stage('Deploy to Staging (Kubeadm)') {
            steps {
                echo "Deploying frontend to kubeadm staging cluster..."
                withCredentials([
                    file(credentialsId: 'kubeconfig-staging', variable: 'KUBECONFIG_FILE'),
                    usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')
                ]) {
                    sh '''
                        set -eu
                        export KUBECONFIG="$KUBECONFIG_FILE"

                        kubectl version --client
                        kubectl apply -f DevOPs/k8s/namespace.yaml
                        kubectl apply -f DevOPs/k8s/frontend-deployment.yaml
                        kubectl apply -f DevOPs/k8s/frontend-service.yaml
                        kubectl -n "$K8S_NAMESPACE" set image deployment/medifollow-frontend-deployment medifollow-frontend="$DOCKER_USER/medifollow-front:latest"
                        kubectl rollout status deployment/medifollow-frontend-deployment -n "$K8S_NAMESPACE" --timeout=180s
                    '''
                }
            }
        }
    }
}
