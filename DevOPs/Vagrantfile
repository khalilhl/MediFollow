Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-22.04"

  # Network: Private IP
  config.vm.network "private_network", ip: "192.168.33.10"
  config.vm.network "public_network", auto_config: true

  # --- PORT FORWARDING ---
  # Jenkins: Guest 8080 -> Host 8080
  config.vm.network "forwarded_port", guest: 8080, host: 8080

  # Your App: Guest 8089 -> Host 8089
  config.vm.network "forwarded_port", guest: 8089, host: 8089

  # Nexus: Guest 8081 (Container) -> Host 8082 (Windows)
  config.vm.network "forwarded_port", guest: 8081, host: 8082

  # SonarQube: Guest 9000 -> Host 9000
  config.vm.network "forwarded_port", guest: 9000, host: 9000

  # Prometheus: Guest 9090 -> Host 9090
  config.vm.network "forwarded_port", guest: 9090, host: 9090

  # Grafana: Guest 3001 -> Host 3001
  config.vm.network "forwarded_port", guest: 3001, host: 3001

  # Kubernetes NodePort range
  config.vm.network "forwarded_port", guest: 30000, host: 30000

  # Hardware
  config.vm.provider "virtualbox" do |vb|
    vb.memory = 6144
    vb.cpus = 2
  end

  # Setup Script
  config.vm.provision "shell", inline: <<-SHELL
    echo "=========================================="
    echo "  MediFollow DevOps - VM Provisioning"
    echo "=========================================="

    # --- Basic Tools ---
    sudo apt-get update -y
    sudo apt-get install -y curl git apt-transport-https ca-certificates gnupg lsb-release software-properties-common

    # --- Docker Installation ---
    echo "[1/5] Installing Docker..."
    sudo mkdir -p /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
    sudo apt-get update -y
    sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
    sudo usermod -aG docker vagrant
    sudo systemctl enable docker
    sudo systemctl start docker

    # Elasticsearch (bundled in SonarQube) requires this on the Docker host
    echo 'vm.max_map_count=262144' | sudo tee /etc/sysctl.d/99-sonarqube.conf > /dev/null
    sudo sysctl -p /etc/sysctl.d/99-sonarqube.conf

    # --- Configure containerd for Kubernetes ---
    sudo mkdir -p /etc/containerd
    containerd config default | sudo tee /etc/containerd/config.toml > /dev/null
    sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml
    sudo systemctl restart containerd

    # --- Kernel Modules & Sysctl for Kubernetes ---
    echo "[2/5] Configuring kernel for Kubernetes..."
    cat <<EOF | sudo tee /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF
    sudo modprobe overlay
    sudo modprobe br_netfilter

    cat <<EOF | sudo tee /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF
    sudo sysctl --system

    # --- Disable Swap (required for kubeadm) ---
    sudo swapoff -a
    sudo sed -i '/ swap / s/^/#/' /etc/fstab

    # --- Install kubeadm, kubelet, kubectl ---
    echo "[3/5] Installing kubeadm, kubelet, kubectl..."
    curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.29/deb/Release.key | sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
    echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.29/deb/ /" | sudo tee /etc/apt/sources.list.d/kubernetes.list
    sudo apt-get update -y
    sudo apt-get install -y kubelet kubeadm kubectl
    sudo apt-mark hold kubelet kubeadm kubectl
    sudo systemctl enable kubelet

    # --- Initialize Kubernetes Cluster ---
    echo "[4/5] Initializing Kubernetes cluster with kubeadm..."
    sudo kubeadm init --pod-network-cidr=10.244.0.0/16 --apiserver-advertise-address=192.168.33.10 --ignore-preflight-errors=NumCPU,Mem

    # Setup kubectl for vagrant user
    mkdir -p /home/vagrant/.kube
    sudo cp -f /etc/kubernetes/admin.conf /home/vagrant/.kube/config
    sudo chown vagrant:vagrant /home/vagrant/.kube/config
    export KUBECONFIG=/home/vagrant/.kube/config

    # Allow scheduling pods on the master node (single-node cluster)
    kubectl taint nodes --all node-role.kubernetes.io/control-plane- || true

    # --- Install Flannel CNI ---
    echo "[5/5] Installing Flannel CNI network plugin..."
    kubectl apply -f https://raw.githubusercontent.com/flannel-io/flannel/master/Documentation/kube-flannel.yml

    echo "=========================================="
    echo "  VM Provisioning Complete!"
    echo "  Docker + Kubeadm + kubectl installed"
    echo "  Kubernetes cluster initialized"
    echo "=========================================="
  SHELL
end