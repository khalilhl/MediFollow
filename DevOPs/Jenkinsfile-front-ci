pipeline {
    agent any
    

    
    stages {
        stage('Checkout Repository') {
            steps {
                checkout scm
            }
        }
        stage('Install Front-End Dependencies') {
            steps {
                dir('Front_End/CODE-REACT') {
                    sh 'npm install --legacy-peer-deps'
                }
            }
        }
        stage('Run React Unit Tests') {
            steps {
                dir('Front_End/CODE-REACT') {
                    sh 'npm run test'
                }
            }
        }
    }
    
    post {
        success {
            // Automatically trigger the Frontend CD pipeline when CI passes!
            build job: 'MediFollow-Front-CD', wait: false
        }
    }
}
