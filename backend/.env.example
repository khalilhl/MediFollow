# MongoDB Atlas - Remplacez par votre connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/medifollow?retryWrites=true&w=majority

# JWT - Changez en production
JWT_SECRET=medifollow-secret-key-change-in-production

# Messagerie : chiffrement AES-256-GCM des textes / chemins audio en base (64 caractères hex = 32 octets)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MESSAGE_ENCRYPTION_KEY=

# MFA - Email de confirmation
FRONTEND_URL=http://localhost:5174
# Serveur SMTP (ex: smtp.gmail.com pour Gmail - pas l'adresse email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=mot-de-passe-application
# Avec smtp.gmail.com : utilisez le même compte que SMTP_USER (ou un alias « Envoyer en tant que » dans Gmail).
# Un From du type noreply@autredomaine.com est en général refusé par Gmail sans alias.
SMTP_FROM=MediFollow <votre-email@gmail.com>

# Copie des messages internes vers la boîte du destinataire (Gmail, etc.) — nécessite SMTP ci-dessus.
# Mettre false pour désactiver (défaut : actif si SMTP est configuré).
MAIL_MIRROR_SMTP=true

# Détection IRM cérébrale (Python + TensorFlow) — dossier contenant brain_tumor_predict_cli.py et le modèle (.keras ou .h5)
# Si l’API est lancée depuis backend/, le défaut est ../brain-tumor-detection (relatif au cwd).
# BRAIN_TUMOR_ROOT=C:\chemin\vers\MediFollow\brain-tumor-detection
# BRAIN_TUMOR_MODEL=C:\chemin\vers\brain_tumor_resnet.keras
# Interpréteur Python avec TensorFlow (sinon le service utilise brain-tumor-detection/.venv/... si présent).
# Mettre le chemin entre guillemets ou avec / pour éviter que dotenv interprète \U dans C:\Users\...
# BRAIN_TUMOR_PYTHON="C:/chemin/vers/brain-tumor-detection/.venv/Scripts/python.exe"
