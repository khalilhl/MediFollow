pipeline {
    agent any
    environment {
        K8S_NAMESPACE = 'medifollow-staging'
    }
    
    stages {
        stage('Checkout Repository') {
            steps {
                checkout scm
            }
        }
        stage('Build Docker Image (Node)') {
            steps {
                dir('backend') {
                    echo "Building Backend Docker Image..."
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                        sh 'docker build --network=host -t "$DOCKER_USER/medifollow-backend:latest" .'
                    }
                }
            }
        }
        stage('Push to DockerHub') {
            steps {
                echo "Logging into DockerHub (bypassing 2FA via Token) and pushing backend image..."
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                    sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                    sh 'docker push "$DOCKER_USER/medifollow-backend:latest"'
                }
            }
        }
        stage('Deploy to Production (Render)') {
            steps {
                echo "Triggering Render via Webhook..."
            }
        }
        stage('Deploy to Staging (Kubeadm)') {
            steps {
                echo "Deploying backend to kubeadm staging cluster..."
                withCredentials([
                    file(credentialsId: 'kubeconfig-staging', variable: 'KUBECONFIG_FILE'),
                    usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER'),
                    string(credentialsId: 'k8s-mongo-uri', variable: 'MONGO_URI'),
                    string(credentialsId: 'k8s-cloudinary-url', variable: 'CLOUDINARY_URL')
                ]) {
                    sh '''
                        set -eu
                        export KUBECONFIG="$KUBECONFIG_FILE"

                        kubectl version --client
                        kubectl apply -f DevOPs/k8s/namespace.yaml

                        kubectl -n "$K8S_NAMESPACE" create secret generic medifollow-secrets \
                          --from-literal=MONGO_URI="$MONGO_URI" \
                          --from-literal=CLOUDINARY_URL="$CLOUDINARY_URL" \
                          --dry-run=client -o yaml | kubectl apply -f -

                        kubectl apply -f DevOPs/k8s/backend-deployment.yaml
                        kubectl apply -f DevOPs/k8s/backend-service.yaml
                        kubectl -n "$K8S_NAMESPACE" set image deployment/medifollow-backend-deployment medifollow-backend="$DOCKER_USER/medifollow-backend:latest"
                        kubectl rollout status deployment/medifollow-backend-deployment -n "$K8S_NAMESPACE" --timeout=180s
                    '''
                }
            }
        }
    }
}
